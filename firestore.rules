rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para la colección 'users'
    match /users/{userId} {
      // Permitir leer y escribir solo si el usuario autenticado es el propietario del documento
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Opcional: Denegar acceso por defecto a otras colecciones si no hay reglas específicas
    match /{document=**} { allow read, write: if false; }
  }
}